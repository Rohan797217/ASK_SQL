# ============================================
# AskSQL .gitignore
# ============================================

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/
*.egg

# --- Virtual environments ---
venv/
env/
.venv/
.env

# --- IDE ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Chroma vector DB (generated, not committed) ---
backend/chroma_db/

# --- Node / React ---
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.env
frontend/.env.local

# --- Logs ---
*.log
npm-debug.log*

# --- OS ---
.DS_Store
*.DS_Store
Thumbs.db
desktop.ini

# --- Testing ---
.pytest_cache/
.coverage
htmlcov/
