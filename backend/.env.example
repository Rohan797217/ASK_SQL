# ============================================
# AskSQL Environment Variables
# Copy this file to .env and fill in your keys
# ============================================

# --- Database ---
# Get a free Postgres DB at https://neon.tech
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# --- LLM Providers ---
# Primary: Google Gemini (https://aistudio.google.com/apikey)
GOOGLE_API_KEY=your_google_api_key_here

# Backup: Groq (https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# Local: Ollama (install from https://ollama.ai, then run: ollama pull llama3.1:8b)
OLLAMA_BASE_URL=http://localhost:11434

# --- App Settings ---
# Max rows returned per query (safety limit)
MAX_QUERY_ROWS=500

# Query execution timeout in seconds
QUERY_TIMEOUT=10

# LLM model names (override defaults if needed)
GEMINI_MODEL=gemini-2.5-flash
GROQ_MODEL=llama-3.3-70b-versatile
OLLAMA_MODEL=llama3.1:8b
